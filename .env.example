# Frontend (Vite) config. Copy to .env.local for local dev.

# Base URL of the Brain API. Defaults to http://localhost:8000 when unset.
VITE_API_BASE_URL=http://localhost:8000

# Optional: if the backend has BRAIN_API_KEY set, put the same value here so the
# browser sends X-API-Key. Leave empty for local dev (open API).
VITE_API_KEY=
