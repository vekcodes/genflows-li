# Copy to .env and adjust. All vars are prefixed BRAIN_.

# --- Storage ---
BRAIN_DATABASE_URL=sqlite:///./brain.db

# --- Apify (LinkedIn scraping) ---
# Required for scraping LinkedIn profiles and company pages.
# Get a token at https://apify.com → Settings → Integrations → API tokens.
BRAIN_APIFY_TOKEN=apify_api_...
BRAIN_APIFY_LINKEDIN_PROFILE_ACTOR=harvestapi/linkedin-profile-posts
BRAIN_APIFY_LINKEDIN_COMPANY_ACTOR=harvestapi/linkedin-company-posts
# Max posts to fetch per source per ingest run.
BRAIN_APIFY_POST_LIMIT=50

# --- Ingestion ---
BRAIN_COMMENT_LIMIT=200

# --- Scraping politeness ---
# Random pause between API calls. Set BOTH to 0 for fast local testing.
BRAIN_SCRAPE_MIN_DELAY_SEC=2
BRAIN_SCRAPE_MAX_DELAY_SEC=5
BRAIN_SCRAPE_MAX_RETRIES=3
BRAIN_SCRAPE_BACKOFF_BASE_SEC=2

# --- Scheduler (continuous re-check). Off by default in dev. ---
BRAIN_SCHEDULER_ENABLED=false
BRAIN_SCHEDULER_INTERVAL_MINUTES=30
BRAIN_DEFAULT_CADENCE_HOURS=24

# --- LLM provider (the reasoning engine) ---
# claude_cli = use your Claude subscription via the Claude Code CLI (no API billing).
#   Install Claude Code and log in, OR generate a token with `claude setup-token`
#   and paste it below as BRAIN_CLAUDE_CODE_OAUTH_TOKEN.
# anthropic  = pay-per-token API key fallback.
# none       = disable LLM mining endpoints.
BRAIN_LLM_PROVIDER=claude_cli
BRAIN_CLAUDE_CLI_PATH=claude
BRAIN_CLAUDE_MODEL=claude-opus-4-8
# BRAIN_CLAUDE_CODE_OAUTH_TOKEN=

# Fallback only:
# BRAIN_ANTHROPIC_API_KEY=sk-ant-...

# --- API security ---
# Set a secret password to gate the API (recommended for deployed instances).
# BRAIN_API_KEY=your-secret-password
