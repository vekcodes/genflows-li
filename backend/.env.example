# Copy to .env and adjust. All vars are prefixed BRAIN_.

# --- Storage ---
BRAIN_DATABASE_URL=sqlite:///./brain.db

# --- Ingestion ---
BRAIN_COMMENT_LIMIT=200

# Two independent backends:
#  • Video signals + comments — BRAIN_SCRAPE_PROVIDER: ytdlp (local, free, returns comments)
#    or apify (needs BRAIN_APIFY_VIDEO_ACTOR). Falls back to yt-dlp on any Apify error.
#  • Transcripts — used automatically whenever the token + transcript actor are set (no need to
#    flip the provider). Apify's residential proxies bypass the caption IP-block. Falls back to
#    the local caption API / Whisper on error. Validated against the codepoetry actor below.
BRAIN_SCRAPE_PROVIDER=ytdlp
# BRAIN_APIFY_TOKEN=apify_api_...
# BRAIN_APIFY_VIDEO_ACTOR=streamers~youtube-scraper   # placeholder — set your own for video-via-apify
BRAIN_APIFY_TRANSCRIPT_ACTOR=codepoetry~youtube-transcript-ai-scraper
BRAIN_APIFY_TRANSCRIPT_LANGUAGES=en
BRAIN_APIFY_ENABLE_AI_FALLBACK=false   # true = pay for AI transcription when a video has no captions
# BRAIN_APIFY_TIMEOUT_SEC=300

# --- Scraping politeness (protects the residential IP) ---
# Random pause between videos. Set BOTH to 0 for fast local testing.
BRAIN_SCRAPE_MIN_DELAY_SEC=2
BRAIN_SCRAPE_MAX_DELAY_SEC=5
BRAIN_SCRAPE_MAX_RETRIES=3
BRAIN_SCRAPE_BACKOFF_BASE_SEC=2
# Hard ceiling on videos scraped per rolling hour, across all sources.
BRAIN_SCRAPE_HOURLY_VIDEO_CAP=300

# --- Scheduler (continuous re-check). Off by default in dev. ---
BRAIN_SCHEDULER_ENABLED=false
BRAIN_SCHEDULER_INTERVAL_MINUTES=30
BRAIN_DEFAULT_CADENCE_HOURS=24

# --- LLM provider (the reasoning engine) ---
# claude_cli = use your Claude subscription via the Claude Code CLI (no API billing).
#   Install Claude Code and log in, OR generate a token with `claude setup-token`
#   and paste it below as BRAIN_CLAUDE_CODE_OAUTH_TOKEN.
# anthropic  = pay-per-token API key fallback.
# none       = disable LLM mining endpoints.
BRAIN_LLM_PROVIDER=claude_cli
BRAIN_CLAUDE_CLI_PATH=claude
BRAIN_CLAUDE_MODEL=claude-opus-4-8
# BRAIN_CLAUDE_CODE_OAUTH_TOKEN=

# Fallback only:
# BRAIN_ANTHROPIC_API_KEY=sk-ant-...
